# ============================================================================
# Bakwas environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values you need.
# You only need keys for the providers you plan to use. Any provider whose
# key is missing is hidden from the UI automatically.
# ============================================================================

# --- Provider API keys ------------------------------------------------------
# Each variable name matches the `api_key_env` value in config/providers.yaml.
# Uncomment and set the ones you want to enable.

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# OpenAI (GPT models)
# OPENAI_API_KEY=

# Google Gemini
# GEMINI_API_KEY=

# OpenRouter (gateway to many providers with one key)
# OPENROUTER_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# Groq (fast inference)
# GROQ_API_KEY=

# Together AI
# TOGETHER_API_KEY=

# Any custom OpenAI-compatible proxy / gateway. Name the variable to match
# the `api_key_env` you set in config/providers.yaml for that provider.
# MY_PROXY_API_KEY=

# --- Server configuration ---------------------------------------------------
# Port the Flask app listens on
PORT=5000

# DEBUG=True disables rate limits locally and shows detailed errors
DEBUG=False

# --- Security ---------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-hex-string
